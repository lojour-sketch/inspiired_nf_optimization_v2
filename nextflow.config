process {
    executor = "slurm"
    queue = "short"

    // Configuración de reintentos
    errorStrategy = { task.attempt <= 2 ? "retry" : "finish" }
    maxRetries = 2

    // ============================================
    // RECURSOS POR PROCESO
    // ============================================
    withName:NORMALIZE_index_length_local {
        cpus = 1
        memory = "500MB"
    }
    withName:CREATE_demux_samplesheet_local {
        cpus = 15
        memory = "5GB"
    }
    withName:BCL2FASTQ_local {
        container = "quay.io/nf-core/bcl2fastq:2.20.0.422"
        cpus = 15
        memory = "30GB"
    }
    withName:DEMUXING_FASTQ_local {
        container = "quay.io/biocontainers/fqtk:0.3.1--ha6fb395_3"
        cpus = 15
        memory = "20GB"
    }
    withName:UMIEXTRACT_local {
        container = "quay.io/biocontainers/umi_tools:1.1.5--py39hbcbf7aa_4"
        cpus = 8
        memory = "5GB"
    }
    withName:FASTQC_RAW {
        container = "biocontainers/fastqc:v0.11.9_cv8"
        cpus = 3
        memory = "8GB"

    }
    withName:TRIMGALORE {
        cpus = 5
        memory = "2GB"
    }
    withName:N_REMOVING {
        container = "staphb/seqkit"
        cpus = 3
        memory = "1GB"
    }
    withName:FASTQC_TRIMMED {
        container = "biocontainers/fastqc:v0.11.9_cv8"
        cpus = 3
        memory = "8GB"
    }
    withName:LTRchecking_seqkit_local {
        container = "staphb/seqkit"
        cpus = 5
        memory = "1GB"
    }
    withName:RCremoval_inspiired_local {
        container = "quay.io/biocontainers/bioconductor-shortread:1.64.0--r44h77050f0_1"
        cpus = 3
        memory = "30GB"
    }
    withName:FINDVECTOR_local {
        container = "${params.runfolderDir}/../containers/shortread_minimap2.sif"
        cpus = 3
        memory = "15GB"
    }
    withName:SHORTREMOVE_local {
        container = "staphb/seqkit"
        cpus = 3
        memory = "5GB"
    }
    withName:GENOME_INDEXING_local {
        container = "quay.io/biocontainers/star:2.7.11b--h5ca1c30_6"
        cpus = 10
        memory = "60GB"
    }
    withName:ALIGNMENT_local {
        container = "quay.io/biocontainers/star:2.7.11b--h5ca1c30_6"
        cpus = 8
        memory = "30GB"
    }
    withName:BAM_TO_ALLSITES_local {
        container = "quay.io/biocontainers/pysam:0.23.3--py39hdd5828d_1"
        cpus = 3
        memory = "1GB"
    }
    withName:ALLSITES_TO_SITESFINAL_edited_grouping_local {
        container = "${params.runfolderDir}/../containers/sitesfinal_rpackages.sif"
        cpus = 3
        memory = "5GB"
    }
    withName:INDEX_SORT_BAM_local {
        container = "${params.runfolderDir}/../containers/umi_samtools.sif"
        cpus = 3
        memory = "3GB"
    }
    withName:MULTIQC {
        container = "docker://quay.io/biocontainers/multiqc:1.19--pyhdfd78af_0"
        cpus = 3
        memory = "1GB"
    }
    withName:SITESFINAL_TO_POINTS_local {
        container = "${params.runfolderDir}/../containers/annotation.sif"
        cpus = 3
        memory = "5GB"
    }
}

// ============================================
// EXECUTOR SETTINGS - CONSERVATIVE
// ============================================
executor {
    name = "slurm"
    queueSize = 10                    // ⚡ Max 10 jobs en cola
    submitRateLimit = "1/5sec"       // 1 job cada 5 segundos
    pollInterval = "15 sec"
    queueStatInterval = "1 min"
}

singularity {
    enabled = true
    runOptions = "--fakeroot --bind ${params.runfolderDir}/../"
    autoMounts = true
}

manifest {
  name = "liberentaizp/inspiired_nf_optimization"
  version = "1.0.0"
  description = "Viral integration detection pipeline on Nextflow based on INSPIIRED software."
  author = "Libe Renteria <liberenteria@gmail.com>"
}

report {
    enabled = true
    file = "report.html"
    overwrite = true
}

trace {
    overwrite = true
}